# Node.js
# Standard Node.js dependency directory
node_modules/

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnpm-store/

# Environment variables
# Local environment variables, typically not committed to version control.
# If using a .env file for configuration, it should be ignored.
.env
.env.local
.env.*.local

# Build artifacts
# Webpack output directory. This directory contains the compiled and bundled
# application code, which should be generated, not committed.
dist/
build/

# Editor/IDE specific files
# Visual Studio Code
.vscode/
# IntelliJ IDEA / WebStorm
.idea/

# Operating System files
# macOS
.DS_Store
# Windows
Thumbs.db

# Temporary files
*.tmp
*.bak
*.swp
*~

# Test coverage reports
coverage/

# Webpack specific
# Webpack stats file, if generated
webpack-stats.json

# Other potential temporary or generated files
# Any other files that are generated during development or build processes
# and should not be committed.
*.log
*.pid
*.seed
.npm/