{
  "name": "html-canvas-drawing-board",
  "version": "1.0.0",
  "description": "An interactive HTML Canvas drawing application allowing users to draw with different colors and brush sizes, clear the canvas, and save their creations. Part of a larger interconnected system including a Dynamic Color Palette Generator, Live Markdown Editor, and Interactive Kanban Board.",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "webpack --mode production",
    "lint": "eslint \"{src,public}/**/*.js\"",
    "lint:fix": "eslint \"{src,public}/**/*.js\" --fix",
    "format": "prettier --write \"{src,public}/**/*.{js,html,css,json,md}\"",
    "test": "echo \"No tests specified yet\" && exit 0"
  },
  "keywords": [
    "html-canvas",
    "drawing-board",
    "javascript",
    "frontend",
    "interactive",
    "webpack",
    "creative-tool",
    "microservice-integration",
    "color-palette",
    "markdown-editor",
    "kanban-board"
  ],
  "author": "Your Name/Organization",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-loader": "^9.1.3",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "css-minimizer-webpack-plugin": "^6.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.8.1",
    "prettier": "^3.2.5",
    "style-loader": "^3.3.4",
    "terser-webpack-plugin": "^5.3.10",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}